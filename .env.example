# Copy this file to .env and fill in real values.
# .env is listed in .gitignore and will never be committed.

# Required for the EpiGem AI chatbot. Get a free key at https://console.groq.com
# Without this, everything else in Epiworld (dashboard, forecasting, upload,
# risk map) still works -- only the chatbot is disabled.
GROQ_API_KEY=

# Optional -- override the Groq model or endpoint
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_URL=https://api.groq.com/openai/v1/chat/completions

# Optional -- Flask server settings (defaults shown)
# EPIWORLD_HOST=127.0.0.1
# EPIWORLD_PORT=5000
# EPIWORLD_DEBUG=false

# Optional -- forecasting defaults (defaults shown)
# EPIWORLD_DEFAULT_HORIZON=5
# EPIWORLD_MAX_HORIZON=20
